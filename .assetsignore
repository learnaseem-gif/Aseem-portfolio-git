# Files here are NOT uploaded to Cloudflare's static hosting.
.git
.claude
uploads
node_modules
*.md
.gitignore
wrangler.jsonc
.assetsignore

# Cloudflare's static-asset limit is 25 MiB per file. Videos under that
# ship from the repo directly; anything larger is hosted on R2 instead
# (see js/projects.js) and referenced by full URL, not a local path.
